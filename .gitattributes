# Auto-detect line endings — check into git as LF, check out as native
* text=auto

# Python — LF always
*.py text eol=lf

# Markdown — LF always
*.md text eol=lf

# HTML/JS/CSS — LF always
*.html text eol=lf
*.js text eol=lf
*.css text eol=lf

# YAML/JSON — LF always
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Shell scripts — LF always
*.sh text eol=lf

# Windows-specific — CRLF always
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaries — do not touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
